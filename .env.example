# Copy this to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (railcar.db). Set to a Postgres DSN for cloud.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Vision providers (set the one you use) ─────────────────────────────────
# Which provider to use: gemini | anthropic | openai | ollama
VISION_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash-lite
# GEMINI_API_KEY=

# ANTHROPIC_API_KEY=

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Ollama (local open-source models, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5vl:7b

# ── Supabase (Phase 3-4 — auth + file storage) ───────────────────────────────
# Leave unset to store uploads locally in ./uploads/ and skip auth
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key        ← secret, server-side only
# SUPABASE_ANON_KEY=your-anon-key           ← safe for browser, injected into HTML

# ── Auth (Phase 3) ───────────────────────────────────────────────────────────
# Set to any non-empty value to bypass JWT auth entirely (local dev only)
AUTH_DISABLED=true
