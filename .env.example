# Copy this file to .env and fill in your values.

# Which vision provider to use: anthropic (default), openai, or ollama
VISION_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Ollama (local open-source models, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llava
