# Ollama setup

# Which vision provider to use: 
# anthropic (default), openai, or ollama
VISION_PROVIDER=ollama

# Anthropic 
#ANTHROPIC_API_KEY=

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite 

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

Ollama (local open-source models, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5vl:7b

